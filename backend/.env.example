# ─── Backend configuration ───────────────────────────────────────────────
# Copy this file to `.env` and adjust for your environment.
#   cp backend/.env.example backend/.env

# --- Server ---
HOST=0.0.0.0
PORT=8000
# Auto-reload the server on code changes. Use only in local development.
RELOAD=false
# Exposes the /api/debug/tasks endpoint. Keep false in production.
DEBUG=false

# --- CORS ---
# Comma-separated list of origins allowed to call the API (no trailing slash).
# Local dev:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production example:
# CORS_ORIGINS=https://your-frontend-domain.com

# --- Storage ---
# Directory for temporary downloaded/processed files.
# Leave unset to use the default backend/temp folder.
# TEMP_DIR=/var/data/streamextractor/temp

# --- Cleanup ---
# Seconds to keep a finished file on disk before deleting it after download.
FILE_CLEANUP_DELAY=5
